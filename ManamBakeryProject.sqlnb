cells:
  - kind: 1
    value: Drop Table
    languageId: markdown
  - kind: 2
    value: "BEGIN EXECUTE IMMEDIATE 'DROP TABLE feedback CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE delivery CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE payment CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE order_details CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE orders CASCADE CONSTRAINTS'; EXCEPTION
      WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE inventory CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE product CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE category CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE supplier CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE employee CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE membership CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE branch CASCADE CONSTRAINTS'; EXCEPTION
      WHEN OTHERS THEN NULL; END;\r

      /\r

      \r

      BEGIN EXECUTE IMMEDIATE 'DROP TABLE customer CASCADE CONSTRAINTS';
      EXCEPTION WHEN OTHERS THEN NULL; END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Create tables
    languageId: markdown
  - kind: 1
    value: Customer
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE customer\r

      (\r

      \    customer_id NUMBER PRIMARY KEY,\r

      \    first_name VARCHAR2(30),\r

      \    last_name VARCHAR2(30),\r

      \    phone VARCHAR2(20),\r

      \    city VARCHAR2(30)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Membership
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE membership\r

      (\r

      \    membership_id NUMBER PRIMARY KEY,\r

      \    customer_id NUMBER,\r

      \    membership_type VARCHAR2(20),\r

      \    points NUMBER,\r

      \    FOREIGN KEY(customer_id)\r

      \    REFERENCES customer(customer_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Branch
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE branch\r

      (\r

      \    branch_id NUMBER PRIMARY KEY,\r

      \    branch_name VARCHAR2(50),\r

      \    address VARCHAR2(100)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Employee
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE employee\r

      (\r

      \    employee_id NUMBER PRIMARY KEY,\r

      \    employee_name VARCHAR2(50),\r

      \    salary NUMBER,\r

      \    branch_id NUMBER,\r

      \    FOREIGN KEY(branch_id)\r

      \    REFERENCES branch(branch_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Supplier
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE supplier\r

      (\r

      \    supplier_id NUMBER PRIMARY KEY,\r

      \    supplier_name VARCHAR2(50),\r

      \    city VARCHAR2(30)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Category
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE category\r

      (\r

      \    category_id NUMBER PRIMARY KEY,\r

      \    category_name VARCHAR2(30)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Product
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE product\r

      (\r

      \    product_id NUMBER PRIMARY KEY,\r

      \    product_name VARCHAR2(50),\r

      \    price NUMBER,\r

      \    category_id NUMBER,\r

      \    supplier_id NUMBER,\r

      \r

      \    FOREIGN KEY(category_id)\r

      \    REFERENCES category(category_id),\r

      \r

      \    FOREIGN KEY(supplier_id)\r

      \    REFERENCES supplier(supplier_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Inventory
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE inventory\r

      (\r

      \    inventory_id NUMBER PRIMARY KEY,\r

      \    product_id NUMBER,\r

      \    quantity NUMBER,\r

      \    FOREIGN KEY(product_id)\r

      \    REFERENCES product(product_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Orders
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE orders\r

      (\r

      \    order_id NUMBER PRIMARY KEY,\r

      \    customer_id NUMBER,\r

      \    employee_id NUMBER,\r

      \    order_date DATE,\r

      \r

      \    FOREIGN KEY(customer_id)\r

      \    REFERENCES customer(customer_id),\r

      \r

      \    FOREIGN KEY(employee_id)\r

      \    REFERENCES employee(employee_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Order details
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE order_details\r

      (\r

      \    detail_id NUMBER PRIMARY KEY,\r

      \    order_id NUMBER,\r

      \    product_id NUMBER,\r

      \    quantity NUMBER,\r

      \r

      \    FOREIGN KEY(order_id)\r

      \    REFERENCES orders(order_id),\r

      \r

      \    FOREIGN KEY(product_id)\r

      \    REFERENCES product(product_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Payment
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE payment\r

      (\r

      \    payment_id NUMBER PRIMARY KEY,\r

      \    order_id NUMBER,\r

      \    amount NUMBER,\r

      \    payment_method VARCHAR2(20),\r

      \    FOREIGN KEY(order_id)\r

      \    REFERENCES orders(order_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Delivery
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE delivery\r

      (\r

      \    delivery_id NUMBER PRIMARY KEY,\r

      \    order_id NUMBER,\r

      \    delivery_status VARCHAR2(20),\r

      \r

      \    FOREIGN KEY(order_id)\r

      \    REFERENCES orders(order_id)\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: Feedback
    languageId: markdown
  - kind: 2
    value: "CREATE TABLE feedback\r

      (\r

      \    feedback_id NUMBER PRIMARY KEY,\r

      \    customer_id NUMBER,\r

      \    rating NUMBER,\r

      \    comments VARCHAR2(100),\r

      \    FOREIGN KEY(customer_id)\r

      \    REFERENCES customer(customer_id)\r

      );"
    languageId: oracle-sql
