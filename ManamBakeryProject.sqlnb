    languageId: oracle-sql
  - kind: 1
    value: Select
    languageId: markdown
  - kind: 2
    value: SELECT * FROM customer;
    languageId: oracle-sql
  - kind: 1
    value: Where
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM product\r

      WHERE price > 200;"
    languageId: oracle-sql
  - kind: 1
    value: Order by
    languageId: markdown
  - kind: 2
    value: "SELECT * FROM product\r

      ORDER BY price DESC;"
    languageId: oracle-sql
  - kind: 1
    value: Group by
    languageId: markdown
  - kind: 2
    value: "SELECT category_id, AVG(price)\r

      FROM product\r

      GROUP BY category_id;"
    languageId: oracle-sql
  - kind: 1
    value: Having
    languageId: markdown
  - kind: 2
    value: "SELECT category_id, AVG(price)\r

      FROM product\r

      GROUP BY category_id\r

      HAVING AVG(price) > 200;"
    languageId: oracle-sql
  - kind: 1
    value: Aggregate
    languageId: markdown
  - kind: 2
    value: "SELECT COUNT(*) AS total_products\r

      FROM product;\r

      SELECT MAX(price) AS highest_price\r

      FROM product;\r

      SELECT MIN(price) AS lowest_price\r

      FROM product;\r

      SELECT AVG(price) AS average_price\r

      FROM product;\r

      SELECT SUM(price) AS total_price\r

      FROM product;"
    languageId: oracle-sql
  - kind: 1
    value: Inner join
    languageId: markdown
  - kind: 2
    value: "SELECT c.first_name,\r

      \       o.order_id\r

      FROM customer c\r

      JOIN orders o\r

      ON c.customer_id=o.customer_id;"
    languageId: oracle-sql
  - kind: 1
    value: Subquery
    languageId: markdown
  - kind: 2
    value: "SELECT product_name\r

      FROM product\r

      WHERE price >\r

      (\r

      SELECT AVG(price)\r

      FROM product\r

      );"
    languageId: oracle-sql
  - kind: 1
    value: View
    languageId: markdown
  - kind: 2
    value: "CREATE OR REPLACE VIEW customer_orders AS\r

      SELECT c.first_name,\r

      \       o.order_id\r

      FROM customer c\r

      JOIN orders o\r

      ON c.customer_id=o.customer_id;"
    languageId: oracle-sql
  - kind: 1
    value: PL / SQL
    languageId: markdown
  - kind: 1
    value: Variables
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    v_name VARCHAR2(30);\r

      BEGIN\r

      \    SELECT first_name\r

      \    INTO v_name\r

      \    FROM customer\r

      \    WHERE customer_id=1;\r

      \    DBMS_OUTPUT.PUT_LINE(v_name);\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: IF / ELSIF
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    v_price NUMBER:=500;\r

      BEGIN\r

      \    IF v_price>300 THEN\r

      \        DBMS_OUTPUT.PUT_LINE('Expensive');\r

      \    ELSE\r

      \        DBMS_OUTPUT.PUT_LINE('Cheap');\r

      \    END IF;\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Basic loop
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    i NUMBER:=1;\r

      BEGIN\r

      \    LOOP\r

      \        EXIT WHEN i>5;\r

      \        DBMS_OUTPUT.PUT_LINE(i);\r

      \        i:=i+1;\r

      \    END LOOP;\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: WHILE loop
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    counter NUMBER := 1;\r

      BEGIN\r

      \    WHILE counter <= 5\r

      \    LOOP\r

      \        DBMS_OUTPUT.PUT_LINE(\r

      \            'Counter = ' || counter\r

      \        );\r

      \r

      \        counter := counter + 1;\r

      \    END LOOP;\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Numeric for loop
    languageId: markdown
  - kind: 2
    value: "BEGIN\r

      \    FOR i IN 1..5\r

      \    LOOP\r

      \        DBMS_OUTPUT.PUT_LINE('Value = ' || i);\r

      \    END LOOP;\r

      \r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Cursor
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    CURSOR c IS\r

      \    SELECT first_name\r

      \    FROM customer;\r

      \r

      \    v_name customer.first_name%TYPE;\r

      BEGIN\r

      \    OPEN c;\r

      \r

      \    LOOP\r

      \        FETCH c INTO v_name;\r

      \r

      \        EXIT WHEN c%NOTFOUND;\r

      \r

      \        DBMS_OUTPUT.PUT_LINE(v_name);\r

      \    END LOOP;\r

      \r

      \    CLOSE c;\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Procedure
    languageId: markdown
  - kind: 2
    value: "CREATE OR REPLACE PROCEDURE show_customer\r

      (\r

      \    p_id NUMBER\r

      )\r

      AS\r

      \    v_name VARCHAR2(30);\r

      BEGIN\r

      \    SELECT first_name\r

      \    INTO v_name\r

      \    FROM customer\r

      \    WHERE customer_id=p_id;\r

      \r

      \    DBMS_OUTPUT.PUT_LINE(v_name);\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Execute
    languageId: markdown
  - kind: 2
    value: "BEGIN\r

      \    show_customer(1);\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Function
    languageId: markdown
  - kind: 2
    value: "CREATE OR REPLACE FUNCTION total_products\r

      RETURN NUMBER\r

      AS\r

      \    v_count NUMBER;\r

      BEGIN\r

      \    SELECT COUNT(*)\r

      \    INTO v_count\r

      \    FROM product;\r

      \r

      \    RETURN v_count;\r

      END;\r

      /"
    languageId: oracle-sql
  - kind: 1
    value: Execute
    languageId: markdown
  - kind: 2
    value: "DECLARE\r

      \    x NUMBER;\r

      BEGIN\r

      \    x:=total_products;\r

      \    DBMS_OUTPUT.PUT_LINE(x);\r

      END;\r

      /"
    languageId: oracle-sql
